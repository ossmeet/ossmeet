{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ossmeet",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat",
		"no_handle_cross_request_promise_resolution"
	],
	"main": "./src/worker-entry.ts",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"placement": { "mode": "smart" },
	// Rate Limiters (stable top-level key — not unsafe.bindings)
	"ratelimits": [
		{
			"name": "RATE_LIMITER",
			"namespace_id": "1001",
			"simple": { "limit": 100, "period": 60 }
		},
		{
			"name": "AUTH_RATE_LIMITER",
			"namespace_id": "1002",
			"simple": { "limit": 60, "period": 60 }
		}
	],
	// D1 Database
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ossmeet-db",
			"database_id": "10c0197c-5ffc-4552-92e3-9f87e7fb492c",
			"migrations_dir": "../../packages/db/drizzle/migrations"
		}
	],
	// R2 Object Storage
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "ossmeet-files"
		}
	],
	// Environment Variables (non-sensitive)
	"vars": {
			"APP_NAME": "OSSMeet",
			"APP_URL": "https://ossmeet.com",
			"LIVEKIT_URL": "wss://livekit.ossmeet.com",
			"VITE_LIVEKIT_URL": "wss://livekit.ossmeet.com",
		"ENVIRONMENT": "production",
		// Must match r2_buckets[0].bucket_name; used by presigned S3 URLs.
		"R2_BUCKET_NAME": "ossmeet-files",
		"AI_MODEL": "gemini-3.1-flash-lite-preview",
		"AI_MODEL_FALLBACK": "gemma-4-31b-it",
		"UPTIMEROBOT_MONITOR_LIVEKIT_ID": "802910459",
		// Paddle Billing (non-sensitive — safe to commit)
		"PADDLE_ENVIRONMENT": "production",
		// Client-side token for Paddle.js overlay checkout (public)
		"VITE_PADDLE_CLIENT_TOKEN": "live_b44eff52b30d5aa5e456c26ee11",
		// Price IDs from Paddle Catalog → Products (public)
		"PADDLE_PRICE_ID_PRO": "pri_01kpxjentm0z2b31496cbz5k5h",
		"PADDLE_PRICE_ID_ORG": "pri_01kpxt0tv4c93yyejec0f4hqa8"
	},
	// Static assets
	"assets": {
		"binding": "ASSETS",
		// SPA-first on Free plan: only invoke Worker first for dynamic API/RPC routes.
		// Static assets and static HTML should be served directly from Assets when possible.
		"run_worker_first": ["/api/*", "/_serverFn/*"]
	},
	// Custom domains
	// Apex only. `www` should be handled by an external redirect rule, not by
	// deploying a second custom-domain binding for this Worker.
	"routes": [
		{ "pattern": "ossmeet.com", "custom_domain": true }
	],
	// Cron: 5-min lightweight cleanup + 2 AM UTC daily maintenance.
	// Total: ~289 invocations/day — negligible against the 100k/day free quota.
	"triggers": {
		"crons": ["*/5 * * * *", "0 2 * * *"]
	},
	// AI Configuration
	// AI_API_KEY is a secret (set via: wrangler secret put AI_API_KEY)
	// AI_MODEL is a Gemini model ID — set to a current model from Google AI Studio

	// Secrets (set via: wrangler secret put <KEY>)
	// - AI_API_KEY
	// - AUTH_SECRET
	// - GOOGLE_CLIENT_ID
	// - GOOGLE_CLIENT_SECRET
	// - RESEND_API_KEY
	// - LIVEKIT_API_KEY
	// - LIVEKIT_API_SECRET
	// - R2_ACCESS_KEY_ID
	// - R2_SECRET_ACCESS_KEY
	// - R2_ACCOUNT_ID
	// - UPTIMEROBOT_API_KEY
	// - PADDLE_API_KEY
	// - PADDLE_WEBHOOK_SECRET
	// Optional (whiteboard):
	// - WHITEBOARD_URL
	// - WHITEBOARD_INTERNAL_SECRET
	// - WHITEBOARD_JWT_SECRET
	// - TLDRAW_LICENSE_KEY
}
