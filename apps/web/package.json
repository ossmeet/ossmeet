{
  "name": "@ossmeet/web",
  "private": true,
  "type": "module",
  "scripts": {
    "copy:mediapipe": "node ../../scripts/copy-mediapipe-wasm.mjs",
    "sync:private-assets": "node ../../scripts/sync-private-assets.mjs",
    "check:runtime-assets": "node ../../scripts/check-runtime-assets.mjs",
    "dev": "pnpm run copy:mediapipe && pnpm run sync:private-assets && pnpm run check:runtime-assets && vite dev --port 3000",
    "build": "pnpm run copy:mediapipe && pnpm run sync:private-assets && pnpm run check:runtime-assets && vite build",
    "serve": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply ossmeet-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ossmeet-db --remote",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@base-ui/react": "^1.4.1",
    "@floating-ui/dom": "^1.7.6",
    "@livekit/components-react": "^2.9.20",
    "@livekit/track-processors": "^0.7.2",
    "@ossmeet/db": "workspace:*",
    "@ossmeet/shared": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.42",
    "ai": "^6.0.168",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "livekit-client": "^2.18.4",
    "livekit-server-sdk": "^2.15.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.31.2",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/eslint-plugin-query": "^5.99.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "wrangler": "^4.84.1"
  }
}
