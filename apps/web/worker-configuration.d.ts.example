/* eslint-disable */
// Stub type definition for CI and fresh clones.
// The real file is generated by `wrangler types` from your wrangler.jsonc
// and is gitignored because it contains environment-specific values.
declare namespace Cloudflare {
	interface GlobalProps {
		mainModule: typeof import("./src/worker-entry");
	}
	interface Env {
		R2_BUCKET: R2Bucket;
		DB: D1Database;
		RATE_LIMITER: RateLimit;
		AUTH_RATE_LIMITER: RateLimit;
		ASSETS: Fetcher;
		APP_NAME: string;
		APP_URL: string;
		ENVIRONMENT: string;
		AUTH_SECRET: string;
		GOOGLE_CLIENT_ID: string;
		GOOGLE_CLIENT_SECRET: string;
		RESEND_API_KEY: string;
		RESEND_FROM_ADDRESS: string;
		LIVEKIT_URL: string;
		VITE_LIVEKIT_URL: string;
		LIVEKIT_API_KEY: string;
		LIVEKIT_API_SECRET: string;
		R2_ACCESS_KEY_ID: string;
		R2_SECRET_ACCESS_KEY: string;
		R2_ACCOUNT_ID: string;
		R2_BUCKET_NAME: string;
		AI_API_KEY: string;
		AI_MODEL: string;
		AI_MODEL_FALLBACK: string;
		WHITEBOARD_URL: string;
		WHITEBOARD_INTERNAL_SECRET: string;
		WHITEBOARD_JWT_SECRET: string;
		BETTERSTACK_API_KEY: string;
		UPTIMEROBOT_API_KEY: string;
		PADDLE_ENVIRONMENT: string;
		VITE_PADDLE_CLIENT_TOKEN: string;
		PADDLE_API_KEY: string;
		PADDLE_WEBHOOK_SECRET: string;
		PADDLE_PRICE_ID_PRO: string;
		PADDLE_PRICE_ID_ORG: string;
		VITE_TLDRAW_LICENSE_KEY: string;
		COOKIE_DOMAIN: string;
	}
}
interface Env extends Cloudflare.Env {}
type StringifyValues<EnvType extends Record<string, unknown>> = {
	[Binding in keyof EnvType]: EnvType[Binding] extends string ? EnvType[Binding] : string;
};
declare namespace NodeJS {
	interface ProcessEnv extends StringifyValues<Cloudflare.Env> {}
}
