{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "ossmeet",
	"compatibility_date": "2026-03-29",
	"compatibility_flags": [
		"nodejs_compat",
		"no_handle_cross_request_promise_resolution"
	],
	"main": "./src/worker-entry.ts",
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"placement": { "mode": "smart" },
	"ratelimits": [
		{
			"name": "RATE_LIMITER",
			"namespace_id": "1001",
			"simple": { "limit": 100, "period": 60 }
		},
		{
			"name": "AUTH_RATE_LIMITER",
			"namespace_id": "1002",
			"simple": { "limit": 60, "period": 60 }
		}
	],
	// D1 Database — create with: wrangler d1 create ossmeet-db
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ossmeet-db",
			"database_id": "<your-d1-database-id>",
			"migrations_dir": "../../packages/db/drizzle/migrations"
		}
	],
	// R2 Object Storage — create with: wrangler r2 bucket create ossmeet-files
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "ossmeet-files"
		}
	],
	// Environment Variables (non-sensitive)
	"vars": {
		"APP_NAME": "OSSMeet",
		"APP_URL": "https://your-domain.example",
		"LIVEKIT_URL": "wss://livekit.your-domain.example",
		"VITE_LIVEKIT_URL": "wss://livekit.your-domain.example",
		"ENVIRONMENT": "production",
		// Must match r2_buckets[0].bucket_name; used by presigned S3 URLs.
		"R2_BUCKET_NAME": "ossmeet-files",
		"AI_MODEL": "gemini-3.1-flash-lite-preview",
		"AI_MODEL_FALLBACK": "gemma-4-31b-it",
		// tldraw production license — required for non-localhost domains.
		// Obtain from https://tldraw.dev. Leave empty for localhost-only builds.
		"VITE_TLDRAW_LICENSE_KEY": ""
	},
	// Static assets
	"assets": {
		"binding": "ASSETS",
		"run_worker_first": ["/api/*", "/_serverFn/*"]
	},
	// Custom domains — replace with your own
	// "routes": [
	// 	{ "pattern": "your-domain.example", "custom_domain": true }
	// ],
	// Cron: 5-min lightweight cleanup + 2 AM UTC daily maintenance.
	"triggers": {
		"crons": ["*/5 * * * *", "0 2 * * *"]
	}

	// Secrets (set via: wrangler secret put <KEY>)
	// Required:
	// - AUTH_SECRET
	// - LIVEKIT_API_KEY
	// - LIVEKIT_API_SECRET
	// - R2_ACCESS_KEY_ID
	// - R2_SECRET_ACCESS_KEY
	// - R2_ACCOUNT_ID
	//
	// Optional:
	// - AI_API_KEY              (for meeting summaries)
	// - GOOGLE_CLIENT_ID        (for Google OAuth sign-in)
	// - GOOGLE_CLIENT_SECRET
	// - RESEND_API_KEY          (for transactional email)
	// - UPTIMEROBOT_API_KEY     (for /status page)
	// - PADDLE_API_KEY          (for billing)
	// - PADDLE_WEBHOOK_SECRET
}
