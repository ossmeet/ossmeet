# LiveKit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_WS_URL=wss://livekit.ossmeet.com

# Redis
REDIS_PASSWORD=your-redis-password

# Whiteboard server
WHITEBOARD_INTERNAL_SECRET=your-whiteboard-secret-here
WHITEBOARD_JWT_SECRET=your-whiteboard-jwt-secret-here
WHITEBOARD_ALLOWED_ORIGINS=https://ossmeet.com,https://www.ossmeet.com
APP_URL=https://ossmeet.com

# R2 (for PDF upload from VPS)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=ossmeet-files
