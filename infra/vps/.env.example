# Domains — used by Caddy and LiveKit config templates
LIVEKIT_DOMAIN=livekit.your-domain.example
LIVEKIT_TURN_DOMAIN=livekit-turn.your-domain.example
WHITEBOARD_DOMAIN=whiteboard.your-domain.example

# LiveKit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_WS_URL=wss://livekit.your-domain.example

# Redis
REDIS_PASSWORD=your-redis-password

# Whiteboard server
WHITEBOARD_INTERNAL_SECRET=your-whiteboard-secret-here
WHITEBOARD_JWT_SECRET=your-whiteboard-jwt-secret-here
WHITEBOARD_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
APP_URL=https://your-domain.example

# R2 (for PDF upload from VPS)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=ossmeet-files
