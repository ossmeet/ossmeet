{
  "logging": {
    "logs": {
      "default": {
        "level": "INFO",
        "encoder": {
          "format": "json"
        }
      }
    }
  },
  "storage": {
    "module": "file_system",
    "root": "/data"
  },
  "apps": {
    "tls": {
      "certificates": {
        "automate": [
          "livekit-turn.ossmeet.com"
        ]
      }
    },
    "layer4": {
      "servers": {
        "turn_tls": {
          "listen": [":443"],
          "routes": [
            {
              "match": [
                {
                  "tls": {
                    "sni": ["livekit-turn.ossmeet.com"]
                  }
                }
              ],
              "handle": [
                { "handler": "tls" },
                {
                  "handler": "proxy",
                  "upstreams": [{ "dial": ["host.docker.internal:5350"] }]
                }
              ]
            }
          ]
        }
      }
    }
  }
}
